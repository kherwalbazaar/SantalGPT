# SantalGPT Frontend Configuration

# Backend API URL (default: http://localhost:8000)
VITE_API_URL=http://localhost:8000

# For production deployment, change to your server URL:
# VITE_API_URL=https://your-api-domain.com

# Gemini AI API Key (required for AI responses)
# Get your API key from: https://aistudio.google.com/app/apikey
# IMPORTANT: Add this as an environment variable in Vercel project settings
SantaliGPT=your_gemini_api_key_here
# Or use GOOGLE_AI_API_KEY as an alternative
# GOOGLE_AI_API_KEY=your_gemini_api_key_here
